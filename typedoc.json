{
  "name": "Documentation",
  "entryPoints": ["src/**/*.ts"],
  "readme": "README.md",
  "exclude": ["src/**/*.{test,bench,protected,private}.ts", "src/**/*.{protected,private}/**/*.ts"],
  "compilerOptions": {
    "skipLibCheck": true
  },
  "sort": ["static-first", "source-order"],
  "customCss": "typedoc.theme.css",
  "outputs": [
    {
      "name": "html",
      "path": "./docs"
    }
  ]
}
