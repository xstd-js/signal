{
  "name": "@xstd/signal",
  "version": "1.0.2",
  "type": "module",
  "description": "Signal implementation",
  "keywords": [
    "signal",
    "reactive"
  ],
  "author": "Valentin Richard",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xstd-js/signal.git"
  },
  "packageManager": "yarn@4.16.0",
  "main": "./index.js",
  "scripts": {
    "=== FB: BUILD ===": "",
    "fb:build": "fabrique build",
    "=== FB: CODE QUALITY ===": "",
    "fb:format": "yarn format:fix",
    "fb:format:check": "prettier --check --ignore-unknown --config .prettierrc \"./**/*.{js,jsx,ts,tsx,html,css,scss,json,md}\"",
    "fb:format:fix": "prettier --write --ignore-unknown --config .prettierrc \"./**/*.{js,jsx,ts,tsx,html,css,scss,json,md}\"",
    "fb:check": "yarn fb:check:types && yarn fb:format:check",
    "fb:check:types": "tsc -p tsconfig.json --noEmit",
    "=== FB: CI ===": "",
    "fb:ci:release": "fabrique ci release",
    "=== FB: TEST ===": "",
    "fb:test": "vitest",
    "fb:test:coverage": "vitest run --coverage",
    "fb:bench": "vitest bench",
    "=== FB: DOC ===": "",
    "fb:typedoc": "typedoc --options typedoc.json --tsconfig tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@vitest/coverage-istanbul": "^4.1.8",
    "alien-signals": "^3.2.1",
    "fabrique": "2.0.3",
    "prettier": "^3.8.4",
    "prettier-plugin-organize-imports": "^4.3.0",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "access": "public",
  "dependencies": {
    "@xstd/equal-function": "^0.0.1",
    "@xstd/undo-function": "^1.0.0"
  },
  "fabrique": {
    "version": "2.0.3",
    "type": "lib"
  }
}
